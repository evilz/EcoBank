<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Cards"
             xmlns:domain="using:EcoBank.Core.Domain.Cards"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             x:Class="EcoBank.App.Views.Cards.CardsView"
             x:DataType="vm:CardsViewModel"
             Background="#171717">

  <DockPanel Background="#171717">

    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,*,Auto"
          Margin="18,18,18,8">
      <Button Grid.Column="0"
              Classes="IconBtn"
              Width="48"
              Height="48">
        <Border Width="42" Height="42" CornerRadius="13" Background="#242424" BorderBrush="#18FFFFFF" BorderThickness="1">
          <ic:PackIconMaterial Kind="ArrowLeft"
                               Width="20" Height="20"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
        </Border>
      </Button>
      <TextBlock Grid.Column="1"
                 Text="Mes cartes"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="White"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
      <Button Grid.Column="2"
              Classes="IconBtn"
              Width="48"
              Height="48">
        <Border Width="42" Height="42" CornerRadius="13" Background="#242424" BorderBrush="#18FFFFFF" BorderThickness="1">
          <ic:PackIconMaterial Kind="EyeOutline"
                               Width="20" Height="20"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
        </Border>
      </Button>
    </Grid>

    <ProgressBar DockPanel.Dock="Top"
                 IsIndeterminate="True"
                 Height="3"
                 IsVisible="{Binding IsBusy}"/>

    <TextBlock DockPanel.Dock="Top"
               Text="{Binding ErrorMessage}"
               Foreground="#FF6969"
               TextWrapping="Wrap"
               Margin="20,0"
               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="22" Margin="18,8,18,28">

        <Border CornerRadius="0,0,28,28"
                Background="#202020"
                Padding="0,22,0,22"
                Margin="-18,-8,-18,0">
          <StackPanel Spacing="14">
            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
              <Grid ColumnDefinitions="72,*">
                <Border Grid.Column="0"
                        Width="44"
                        Height="88"
                        CornerRadius="10"
                        BorderBrush="#44FFFFFF"
                        BorderThickness="1.5"
                        Opacity="0.72"
                        Margin="20,0,8,0"
                        VerticalAlignment="Center">
                  <ic:PackIconMaterial Kind="Plus"
                                       Width="18" Height="18"
                                       Foreground="#8E8E8E"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                </Border>

                <ItemsControl Grid.Column="1" ItemsSource="{Binding Cards}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="12"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="domain:Card">
                      <Border Width="244"
                              Height="146"
                              CornerRadius="18"
                              Background="#176C58"
                              Padding="18"
                              Margin="0,0,12,0">
                        <Grid RowDefinitions="Auto,*,Auto">
                          <StackPanel Grid.Row="0" Spacing="3">
                            <TextBlock Text="Numéro de carte"
                                       FontSize="11"
                                       Foreground="#AAFFFFFF"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding MaskedPan}"
                                         FontSize="17"
                                         FontWeight="Bold"
                                         Foreground="White"
                                         TextTrimming="CharacterEllipsis"/>
                              <ic:PackIconMaterial Kind="ContentCopy"
                                                   Width="14"
                                                   Height="14"
                                                   Foreground="#BBFFFFFF"
                                                   VerticalAlignment="Center"/>
                            </StackPanel>
                          </StackPanel>

                          <Grid Grid.Row="2" ColumnDefinitions="*,*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                              <TextBlock Text="Expiration" FontSize="10" Foreground="#99FFFFFF"/>
                              <TextBlock Text="12/28" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                              <TextBlock Text="CVV" FontSize="10" Foreground="#99FFFFFF"/>
                              <TextBlock Text="234" FontSize="14" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="VISA"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       FontStyle="Italic"
                                       Foreground="White"
                                       VerticalAlignment="Bottom"/>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
              <Ellipse Width="7" Height="7" Fill="White"/>
              <Ellipse Width="7" Height="7" Fill="#44FFFFFF"/>
              <Ellipse Width="7" Height="7" Fill="#44FFFFFF"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="DarkPanel">
          <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Opérations"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="White"/>
              <TextBlock Grid.Column="1"
                         Text="Voir tout"
                         FontSize="12"
                         FontWeight="Bold"
                         Foreground="#31D6B2"
                         VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="Sécurité"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#8B8B8B"/>

            <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding ManageCardCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Width="42" Height="42" CornerRadius="12" Background="#343434">
                  <ic:PackIconMaterial Kind="LockOutline" Width="20" Height="20" Foreground="#DADADA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Bloquer la carte" FontSize="15" FontWeight="Bold" Foreground="#EDEDED" VerticalAlignment="Center"/>
                <ic:PackIconMaterial Grid.Column="2" Kind="ChevronRight" Width="19" Height="19" Foreground="#777777" VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding ManageCardCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Width="42" Height="42" CornerRadius="12" Background="#343434">
                  <ic:PackIconMaterial Kind="CreditCardLockOutline" Width="20" Height="20" Foreground="#DADADA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Geler la carte" FontSize="15" FontWeight="Bold" Foreground="#EDEDED" VerticalAlignment="Center"/>
                <ic:PackIconMaterial Grid.Column="2" Kind="ChevronRight" Width="19" Height="19" Foreground="#777777" VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding ViewCardDetailsCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Width="42" Height="42" CornerRadius="12" Background="#343434">
                  <ic:PackIconMaterial Kind="ShieldCheckOutline" Width="20" Height="20" Foreground="#DADADA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="3D Secure" FontSize="15" FontWeight="Bold" Foreground="#EDEDED" VerticalAlignment="Center"/>
                <ic:PackIconMaterial Grid.Column="2" Kind="ChevronRight" Width="19" Height="19" Foreground="#777777" VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding ManageAlertsCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Width="42" Height="42" CornerRadius="12" Background="#343434">
                  <ic:PackIconMaterial Kind="KeyVariant" Width="20" Height="20" Foreground="#DADADA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Changer le PIN" FontSize="15" FontWeight="Bold" Foreground="#EDEDED" VerticalAlignment="Center"/>
                <ic:PackIconMaterial Grid.Column="2" Kind="ChevronRight" Width="19" Height="19" Foreground="#777777" VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </StackPanel>
        </Border>

        <TextBlock Text="Autres paramètres"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#777777"
                   Margin="2,-4,0,0"/>

        <Border Classes="DarkPanel" Padding="16">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Border Width="38" Height="38" CornerRadius="11" Background="#243D38">
              <ic:PackIconMaterial Kind="BellOutline" Width="19" Height="19" Foreground="#31D6B2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Alertes de paiement" FontSize="15" FontWeight="Bold" Foreground="#EDEDED"/>
              <TextBlock Text="Temps réel" FontSize="12" Foreground="#8B8B8B"/>
            </StackPanel>
            <Border Grid.Column="2" Background="#1231D6B2" CornerRadius="12" Padding="10,5" VerticalAlignment="Center">
              <TextBlock Text="Actives" FontSize="12" FontWeight="Bold" Foreground="#31D6B2"/>
            </Border>
          </Grid>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </DockPanel>
</UserControl>
