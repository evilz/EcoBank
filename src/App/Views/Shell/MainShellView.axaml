<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Shell"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             x:Class="EcoBank.App.Views.Shell.MainShellView"
             x:DataType="vm:MainShellViewModel"
             Background="#F4F4F4">

  <Panel>

    <Grid ColumnDefinitions="248,*"
          Background="#F4F4F4"
          IsVisible="{Binding $parent[UserControl].Bounds.Width, Converter={x:Static vm:WidthToBoolConverter.IsWide}}">

      <Border Grid.Column="0"
              Background="#171717"
              Padding="18"
              BorderBrush="#101010"
              BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Margin="0,8,0,28" Spacing="18">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Width="42" Height="42" CornerRadius="13" Background="#31D6B2">
                <ic:PackIconMaterial Kind="Leaf"
                                     Width="22" Height="22"
                                     Foreground="#101414"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
              </Border>
              <StackPanel VerticalAlignment="Center" Spacing="1">
                <TextBlock Text="EcoBank" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Banque mobile" FontSize="12" Foreground="#8C8C8C"/>
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:NavTab">
                <Button Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="12"
                        Margin="0,3"
                        CornerRadius="16"
                        Command="{Binding $parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectTabCommand}"
                        CommandParameter="{Binding}">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <ic:PackIconMaterial Kind="{Binding Key, Converter={x:Static vm:NavTabIconConverter.Instance}}"
                                         Width="20" Height="20"
                                         VerticalAlignment="Center">
                      <ic:PackIconMaterial.Foreground>
                        <MultiBinding Converter="{x:Static vm:NavTabActiveColorConverter.Instance}">
                          <Binding Path="Key"/>
                          <Binding Path="$parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectedTab.Key"/>
                        </MultiBinding>
                      </ic:PackIconMaterial.Foreground>
                    </ic:PackIconMaterial>
                    <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                      <TextBlock.Foreground>
                        <MultiBinding Converter="{x:Static vm:NavTabActiveColorConverter.Instance}">
                          <Binding Path="Key"/>
                          <Binding Path="$parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectedTab.Key"/>
                        </MultiBinding>
                      </TextBlock.Foreground>
                    </TextBlock>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <ContentControl Grid.Column="1" Content="{Binding CurrentContent}"/>
    </Grid>

    <Grid RowDefinitions="*,Auto"
          Background="#F4F4F4"
          IsVisible="{Binding $parent[UserControl].Bounds.Width, Converter={x:Static vm:WidthToBoolConverter.IsNarrow}}">

      <ContentControl Grid.Row="0" Content="{Binding CurrentContent}"/>

      <Border Grid.Row="1"
              Background="#F7FFFFFF"
              BoxShadow="0 -12 28 0 #22000000"
              Padding="8,8,8,7"
              CornerRadius="22,22,0,0">
        <ItemsControl ItemsSource="{Binding Tabs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Rows="1"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:NavTab">
              <Button Classes="NavItem"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Command="{Binding $parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectTabCommand}"
                      CommandParameter="{Binding}">
                <StackPanel Spacing="3" HorizontalAlignment="Center">
                  <ic:PackIconMaterial Kind="{Binding Key, Converter={x:Static vm:NavTabIconConverter.Instance}}"
                                       Width="21" Height="21"
                                       HorizontalAlignment="Center">
                    <ic:PackIconMaterial.Foreground>
                      <MultiBinding Converter="{x:Static vm:NavTabActiveColorConverter.Instance}">
                        <Binding Path="Key"/>
                        <Binding Path="$parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectedTab.Key"/>
                      </MultiBinding>
                    </ic:PackIconMaterial.Foreground>
                  </ic:PackIconMaterial>
                  <TextBlock Text="{Binding Label}"
                             FontSize="10"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                      <MultiBinding Converter="{x:Static vm:NavTabActiveColorConverter.Instance}">
                        <Binding Path="Key"/>
                        <Binding Path="$parent[ItemsControl].((vm:MainShellViewModel)DataContext).SelectedTab.Key"/>
                      </MultiBinding>
                    </TextBlock.Foreground>
                  </TextBlock>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Grid>

  </Panel>
</UserControl>
