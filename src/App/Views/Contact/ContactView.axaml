<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Contact"
             xmlns:accounts="using:EcoBank.Core.Domain.Accounts"
             xmlns:payments="using:EcoBank.Core.Domain.Payments"
             xmlns:ic="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="EcoBank.App.Views.Contact.ContactView"
             x:DataType="vm:ContactViewModel"
             Background="#F7FCF8">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,18,16,28" Spacing="16">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Paiements"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#101820"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Classes="IconBtn" Width="44" Height="44" Command="{Binding LoadCommand}">
          <Border Width="40" Height="40" CornerRadius="14" Background="#FFFFFF" BorderBrush="#EEF2F4" BorderThickness="1" BoxShadow="0 2 8 0 #10101820">
            <ic:MaterialIcon Kind="Refresh" Width="20" Height="20" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </Button>
      </Grid>

      <ProgressBar IsIndeterminate="True" Height="3" IsVisible="{Binding IsBusy}"/>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="#D84C4C"
                 TextWrapping="Wrap"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <Border CornerRadius="24"
              Padding="18"
              ClipToBounds="True"
              BoxShadow="0 18 34 0 #22062D1E">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#07351F" Offset="0"/>
            <GradientStop Color="#0B4D2D" Offset="0.52"/>
            <GradientStop Color="#168246" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock Text="Transfert rapide"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="{Binding Message}"
                       FontSize="13"
                       Foreground="#CFE7D8"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding LastPaymentLabel}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"/>
          </StackPanel>
          <ic:MaterialIcon Grid.Column="1"
                           Kind="BankTransfer"
                           Width="78"
                           Height="78"
                           Foreground="#24FFFFFF"
                           VerticalAlignment="Bottom"
                           Margin="8,0,-10,-12"/>
        </Grid>
      </Border>

      <Border Classes="EcoPanel">
        <StackPanel Spacing="14">
          <TextBlock Text="Nouveau virement"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#101820"/>

          <ComboBox ItemsSource="{Binding Accounts}"
                    SelectedItem="{Binding SelectedAccount}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Compte source">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="accounts:Account">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <ComboBox ItemsSource="{Binding Beneficiaries}"
                    SelectedItem="{Binding SelectedBeneficiary}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Bénéficiaire">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="payments:Beneficiary">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBox Classes="EcoField"
                   Text="{Binding Amount}"
                   PlaceholderText="Montant"/>
          <TextBox Classes="EcoField"
                   Text="{Binding PaymentLabel}"
                   PlaceholderText="Libellé"/>

          <CheckBox IsChecked="{Binding IsInstantPayment}"
                    Content="Virement instantané"/>

          <Button Classes="Primary"
                  Command="{Binding SubmitPaymentCommand}"
                  HorizontalAlignment="Stretch">
            <TextBlock Text="Envoyer le paiement" FontWeight="Bold" HorizontalAlignment="Center"/>
          </Button>
        </StackPanel>
      </Border>

      <Border Classes="EcoPanel">
        <StackPanel Spacing="14">
          <TextBlock Text="Bénéficiaires"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#101820"/>
          <ItemsControl ItemsSource="{Binding Beneficiaries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="payments:Beneficiary">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,12">
                  <Border Classes="EcoIconTile">
                    <ic:MaterialIcon Kind="AccountOutline" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#101820"/>
                    <TextBlock Text="{Binding Iban}" FontSize="11" Foreground="#8A9AA5" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11" Foreground="#168246" VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="EcoPanel">
        <StackPanel Spacing="14">
          <TextBlock Text="Prélèvements et mandats"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#101820"/>
          <ItemsControl ItemsSource="{Binding Mandates}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="payments:Mandate">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,12">
                  <Border Classes="EcoIconTile">
                    <ic:MaterialIcon Kind="FileSign" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding CreditorName}" FontSize="14" FontWeight="Bold" Foreground="#101820"/>
                    <TextBlock Text="{Binding Reference}" FontSize="11" Foreground="#8A9AA5" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding Status}" FontSize="11" Foreground="#45545F" VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
