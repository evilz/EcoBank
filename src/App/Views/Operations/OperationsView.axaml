<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Operations"
             xmlns:home="using:EcoBank.App.ViewModels.Home"
             xmlns:domain="using:EcoBank.Core.Domain.Operations"
             xmlns:ic="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="EcoBank.App.Views.Operations.OperationsView"
             x:DataType="vm:OperationsViewModel"
             Background="#FFFFFF">

  <DockPanel Background="#FFFFFF">
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,*,Auto,Auto"
          ColumnSpacing="8"
          Margin="16,14,16,0"
          Height="56">
      <Button Grid.Column="0" Classes="IconBtn" Width="44" Height="44" VerticalAlignment="Center"
              Command="{Binding GoBackCommand}">
        <ic:MaterialIcon Kind="ArrowLeft" Width="22" Height="22" Foreground="#101820" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>

      <TextBlock Grid.Column="1"
                 Text="Transactions"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="#101820"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"/>

      <Button Grid.Column="2" Classes="IconBtn" Width="40" Height="44" VerticalAlignment="Center">
        <ic:MaterialIcon Kind="FilterOutline" Width="22" Height="22" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
      <Button Grid.Column="3" Classes="IconBtn" Width="40" Height="44" VerticalAlignment="Center">
        <ic:MaterialIcon Kind="Magnify" Width="22" Height="22" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
    </Grid>

    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="*,*,*"
          Margin="16,0,16,8"
          Height="44">
      <Grid Grid.Column="0" RowDefinitions="*,2">
        <TextBlock Text="Toutes" FontSize="12" FontWeight="Bold" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Grid.Row="1" Height="2" Background="#168246"/>
      </Grid>
      <TextBlock Grid.Column="1" Text="Entrées" FontSize="12" FontWeight="SemiBold" Foreground="#8A9AA5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="Sorties" FontSize="12" FontWeight="SemiBold" Foreground="#8A9AA5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>

    <Border DockPanel.Dock="Top" Height="1" Background="#EEF2F4"/>

    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" IsVisible="{Binding IsBusy}"/>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="16,16,16,24" Spacing="14">
        <StackPanel Spacing="14" IsVisible="{Binding HasOperations}">
          <TextBlock Text="Aujourd'hui" FontSize="11" FontWeight="SemiBold" Foreground="#8A9AA5"/>

          <ItemsControl ItemsSource="{Binding Operations}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="domain:Operation">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,18"
                      MinHeight="46">
                  <Border Grid.Column="0" Classes="EcoIconTile">
                    <ic:MaterialIcon Kind="{Binding Category, Converter={x:Static home:CategoryToIconConverter.Instance}}"
                                         Width="19"
                                         Height="19"
                                         Foreground="#168246"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                  </Border>

                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#101820"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               Foreground="#45545F"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>

                  <TextBlock Grid.Column="2"
                             FontSize="13"
                             FontWeight="Bold"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0">
                    <TextBlock.Foreground>
                      <Binding Path="Amount" Converter="{x:Static home:AmountToColorConverter.Instance}"/>
                    </TextBlock.Foreground>
                    <TextBlock.Text>
                      <MultiBinding Converter="{x:Static home:SignedMoneyTextConverter.Instance}">
                        <Binding Path="Amount"/>
                        <Binding Path="Currency"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" MinHeight="64" IsVisible="{Binding HasNoOperations}">
          <Border Grid.Column="0" Classes="EcoIconTile">
            <ic:MaterialIcon Kind="ReceiptTextOutline" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
            <TextBlock Text="Aucune opération" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
            <TextBlock Text="Les transactions apparaîtront ici dès qu’elles seront disponibles." FontSize="11" Foreground="#45545F" TextWrapping="Wrap"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
