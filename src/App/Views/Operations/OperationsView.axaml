<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Operations"
             xmlns:home="using:EcoBank.App.ViewModels.Home"
             xmlns:domain="using:EcoBank.Core.Domain.Operations"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             x:Class="EcoBank.App.Views.Operations.OperationsView"
             x:DataType="vm:OperationsViewModel"
             Background="#FFFFFF">

  <DockPanel Background="#FFFFFF">
    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="Auto,*,Auto,Auto"
          ColumnSpacing="8"
          Margin="16,14,16,0"
          Height="56">
      <Button Grid.Column="0" Classes="IconBtn" Width="44" Height="44" VerticalAlignment="Center">
        <ic:PackIconMaterial Kind="ArrowLeft" Width="22" Height="22" Foreground="#101820" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>

      <TextBlock Grid.Column="1"
                 Text="Transactions"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="#101820"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"/>

      <Button Grid.Column="2" Classes="IconBtn" Width="40" Height="44" VerticalAlignment="Center">
        <ic:PackIconMaterial Kind="FilterOutline" Width="22" Height="22" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
      <Button Grid.Column="3" Classes="IconBtn" Width="40" Height="44" VerticalAlignment="Center">
        <ic:PackIconMaterial Kind="Magnify" Width="22" Height="22" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
    </Grid>

    <Grid DockPanel.Dock="Top"
          ColumnDefinitions="*,*,*"
          Margin="16,0,16,8"
          Height="44">
      <Grid Grid.Column="0" RowDefinitions="*,2">
        <TextBlock Text="Toutes" FontSize="12" FontWeight="Bold" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Border Grid.Row="1" Height="2" Background="#168246"/>
      </Grid>
      <TextBlock Grid.Column="1" Text="Entrées" FontSize="12" FontWeight="SemiBold" Foreground="#8A9AA5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="Sorties" FontSize="12" FontWeight="SemiBold" Foreground="#8A9AA5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>

    <Border DockPanel.Dock="Top" Height="1" Background="#EEF2F4"/>

    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="3" IsVisible="{Binding IsBusy}"/>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="16,16,16,24" Spacing="14">
        <StackPanel Spacing="14" IsVisible="{Binding HasOperations}">
          <TextBlock Text="Aujourd'hui" FontSize="11" FontWeight="SemiBold" Foreground="#8A9AA5"/>

          <ItemsControl ItemsSource="{Binding Operations}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="domain:Operation">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,18"
                      MinHeight="46">
                  <Border Grid.Column="0" Classes="EcoIconTile">
                    <ic:PackIconMaterial Kind="{Binding Category, Converter={x:Static home:CategoryToIconConverter.Instance}}"
                                         Width="19"
                                         Height="19"
                                         Foreground="#168246"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                  </Border>

                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#101820"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Category}"
                               FontSize="11"
                               Foreground="#45545F"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>

                  <TextBlock Grid.Column="2"
                             FontSize="13"
                             FontWeight="Bold"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0">
                    <TextBlock.Foreground>
                      <Binding Path="Amount" Converter="{x:Static home:AmountToColorConverter.Instance}"/>
                    </TextBlock.Foreground>
                    <TextBlock.Text>
                      <MultiBinding Converter="{x:Static home:SignedMoneyTextConverter.Instance}">
                        <Binding Path="Amount"/>
                        <Binding Path="Currency"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <StackPanel Spacing="14" IsVisible="{Binding HasNoOperations}">
          <TextBlock Text="Aujourd'hui" FontSize="11" FontWeight="SemiBold" Foreground="#8A9AA5"/>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Classes="EcoIconTile">
              <ic:PackIconMaterial Kind="CartOutline" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Carrefour Bio" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Courses" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="- 42,68 €" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Classes="EcoIconTile">
              <ic:PackIconMaterial Kind="ArrowDown" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Salaire" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Virement" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="+ 2 350,00 €" FontSize="13" FontWeight="Bold" Foreground="#168246" VerticalAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Background="#0F6738" Width="36" Height="36" CornerRadius="18">
              <ic:PackIconMaterial Kind="CoffeeOutline" Width="18" Height="18" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Starbucks" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Restauration" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="- 5,40 €" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
          </Grid>

          <TextBlock Text="Hier" FontSize="11" FontWeight="SemiBold" Foreground="#8A9AA5" Margin="0,4,0,0"/>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Background="#FFF4DF" Width="36" Height="36" CornerRadius="10">
              <ic:PackIconMaterial Kind="Fire" Width="18" Height="18" Foreground="#E8A23A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Planète Énergie" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Énergie" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="- 68,90 €" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Classes="EcoIconTile">
              <ic:PackIconMaterial Kind="ArrowDown" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Virement à Marie" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Virement" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="- 50,00 €" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
          </Grid>

          <TextBlock Text="10 mai 2024" FontSize="11" FontWeight="SemiBold" Foreground="#8A9AA5" Margin="0,4,0,0"/>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Background="#EAF6FA" Width="36" Height="36" CornerRadius="10">
              <ic:PackIconMaterial Kind="ShoppingOutline" Width="18" Height="18" Foreground="#3B82A0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Décathlon" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Shopping" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="- 89,99 €" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" MinHeight="46">
            <Border Grid.Column="0" Classes="EcoIconTile">
              <ic:PackIconMaterial Kind="Leaf" Width="18" Height="18" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Intérêts Livret Éco" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Intérêts" FontSize="11" Foreground="#45545F"/>
            </StackPanel>
            <TextBlock Grid.Column="2" Text="+ 12,45 €" FontSize="13" FontWeight="Bold" Foreground="#168246" VerticalAlignment="Center"/>
          </Grid>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
