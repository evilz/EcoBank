<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Home"
             xmlns:ops="using:EcoBank.Core.Domain.Operations"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             x:Class="EcoBank.App.Views.Home.HomeView"
             x:DataType="vm:HomeViewModel"
             Background="#F4F4F4">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,18,16,28" Spacing="18">

      <Border CornerRadius="0,0,30,30"
              Background="White"
              Padding="18,16,18,20"
              Margin="-16,-18,-16,0"
              BoxShadow="0 16 36 0 #12000000">
        <StackPanel Spacing="26">

          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Text="{Binding WelcomeMessage}"
                         FontSize="28"
                         FontWeight="Bold"
                         Foreground="#171717"/>
              <TextBlock Text="Bienvenue sur EcoBank"
                         FontSize="15"
                         Foreground="#777777"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Classes="IconBtn"
                    Command="{Binding ToggleBalanceCommand}"
                    ToolTip.Tip="Afficher / masquer le solde">
              <Border Width="48" Height="48" CornerRadius="14" Background="#F4F4F4">
                <ic:PackIconMaterial Kind="{Binding IsBalanceVisible, Converter={x:Static vm:BoolToEyeIconConverter.Instance}}"
                                     Width="21" Height="21"
                                     Foreground="#171717"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
              </Border>
            </Button>

            <Button Grid.Column="2" Classes="BellButton">
              <Panel>
                <Border Width="48" Height="48" CornerRadius="14" Background="#F4F4F4">
                  <ic:PackIconMaterial Kind="BellOutline"
                                       Width="21" Height="21"
                                       Foreground="#171717"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                </Border>
                <Ellipse Width="8" Height="8"
                         Fill="#31D6B2"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,9,9,0"/>
              </Panel>
            </Button>
          </Grid>

          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <TextBlock Text="Solde total"
                       FontSize="13"
                       Foreground="#9A9A9A"
                       HorizontalAlignment="Center"/>
            <TextBlock FontSize="39"
                       FontWeight="Bold"
                       Foreground="#171717"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding IsBalanceVisible}">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:N2} {1}">
                  <Binding Path="TotalBalance"/>
                  <Binding Path="Currency"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock FontSize="39"
                       FontWeight="Bold"
                       Foreground="#171717"
                       HorizontalAlignment="Center"
                       Text="•••••• €"
                       IsVisible="{Binding !IsBalanceVisible}"/>
          </StackPanel>

          <UniformGrid Columns="3" ColumnSpacing="12">
            <Button Classes="Secondary" MinHeight="82">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <ic:PackIconMaterial Kind="SwapHorizontal"
                                     Width="24" Height="24"
                                     Foreground="#31D6B2"
                                     HorizontalAlignment="Center"/>
                <TextBlock Text="Virement"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#171717"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="Secondary" MinHeight="82">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <ic:PackIconMaterial Kind="CreditCardOutline"
                                     Width="24" Height="24"
                                     Foreground="#31D6B2"
                                     HorizontalAlignment="Center"/>
                <TextBlock Text="Paiement"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#171717"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="Secondary" MinHeight="82">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <ic:PackIconMaterial Kind="Plus"
                                     Width="24" Height="24"
                                     Foreground="#31D6B2"
                                     HorizontalAlignment="Center"/>
                <TextBlock Text="Ajouter"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#171717"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
          </UniformGrid>
        </StackPanel>
      </Border>

      <Border Classes="FinPanel">
        <StackPanel Spacing="16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Mes cartes"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#171717"/>
            <TextBlock Grid.Column="1"
                       Text="Voir tout"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="#2C5BAA"
                       VerticalAlignment="Center"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Border Grid.Column="0" Width="58" Height="40" CornerRadius="10" Background="#31D6B2">
              <Grid>
                <TextBlock Text="Eco"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="#073B34"
                           Margin="8,6,0,0"/>
                <TextBlock Text="VISA"
                           FontSize="10"
                           FontWeight="Bold"
                           FontStyle="Italic"
                           Foreground="White"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,7,6"/>
              </Grid>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{Binding FirstAccountLabel}"
                         FontSize="13"
                         Foreground="#666666"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock FontSize="18"
                         FontWeight="Bold"
                         Foreground="#171717"
                         IsVisible="{Binding IsBalanceVisible}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:N2} {1}">
                    <Binding Path="FirstAccountBalance"/>
                    <Binding Path="FirstAccountCurrency"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="•••• €"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#171717"
                         IsVisible="{Binding !IsBalanceVisible}"/>
            </StackPanel>
            <Border Grid.Column="2"
                    Background="#EFFFFA"
                    CornerRadius="12"
                    Padding="12,6"
                    VerticalAlignment="Center">
              <TextBlock Text="Active"
                         FontSize="13"
                         FontWeight="Bold"
                         Foreground="#22A887"/>
            </Border>
          </Grid>

          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Border Grid.Column="0" Width="58" Height="40" CornerRadius="10" Background="#145A4D">
              <TextBlock Text="VISA"
                         FontSize="11"
                         FontWeight="Bold"
                         FontStyle="Italic"
                         Foreground="White"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Margin="0,0,7,7"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="Solde à venir" FontSize="13" Foreground="#666666"/>
              <TextBlock FontSize="18" FontWeight="Bold" Foreground="#171717" IsVisible="{Binding IsBalanceVisible}">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0:N2} {1}">
                    <Binding Path="UpcomingBalance"/>
                    <Binding Path="FirstAccountCurrency"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Text="•••• €"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#171717"
                         IsVisible="{Binding !IsBalanceVisible}"/>
            </StackPanel>
          </Grid>

          <Button Background="#FAFAFA"
                  BorderBrush="#E8E8E8"
                  BorderThickness="1"
                  CornerRadius="14"
                  Padding="12"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <ic:PackIconMaterial Kind="Plus" Width="20" Height="20" Foreground="#171717"/>
              <TextBlock Text="Ajouter une carte"
                         FontSize="15"
                         FontWeight="Bold"
                         Foreground="#171717"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <Border Classes="FinPanel">
        <StackPanel Spacing="16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Transactions"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#171717"/>
            <TextBlock Grid.Column="1"
                       Text="Voir tout"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="#2C5BAA"
                       VerticalAlignment="Center"/>
          </Grid>

          <ProgressBar IsIndeterminate="True"
                       Height="3"
                       IsVisible="{Binding IsBusy}"/>

          <TextBlock Text="{Binding ErrorMessage}"
                     Foreground="#FF4D4F"
                     TextWrapping="Wrap"
                     IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <ItemsControl ItemsSource="{Binding RecentOperations}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="ops:Operation">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,14">
                  <Border Grid.Column="0"
                          Width="42" Height="42"
                          CornerRadius="13"
                          Background="#F1F1F1"
                          VerticalAlignment="Center">
                    <ic:PackIconMaterial Kind="{Binding Category, Converter={x:Static vm:CategoryToIconConverter.Instance}}"
                                         Width="19" Height="19"
                                         Foreground="#171717"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#171717"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Aujourd'hui"
                               FontSize="12"
                               Foreground="#8A8A8A"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             FontSize="15"
                             FontWeight="Bold"
                             VerticalAlignment="Center">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0:+#,##0.00;-#,##0.00} {1}">
                        <Binding Path="Amount"/>
                        <Binding Path="Currency"/>
                      </MultiBinding>
                    </TextBlock.Text>
                    <TextBlock.Foreground>
                      <Binding Path="Amount" Converter="{x:Static vm:AmountToColorConverter.Instance}"/>
                    </TextBlock.Foreground>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
