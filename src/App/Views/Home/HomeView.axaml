<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Home"
             xmlns:domain="using:EcoBank.Core.Domain.Accounts"
             xmlns:ic="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="EcoBank.App.Views.Home.HomeView"
             x:DataType="vm:HomeViewModel"
             Background="#F7FCF8">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="0,0,0,24">

      <Border CornerRadius="0,0,30,30"
              Padding="16,16,16,64"
              ClipToBounds="True"
              BoxShadow="0 22 46 0 #300B3B28">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#07351F" Offset="0"/>
            <GradientStop Color="#0B4D2D" Offset="0.55"/>
            <GradientStop Color="#168246" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="1">
                <TextBlock Text="Bonjour"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis">
                  <TextBlock.Text>
                    <Binding Path="GreetingName"/>
                  </TextBlock.Text>
                </TextBlock>
              </StackPanel>

              <Button Grid.Column="1"
                      Classes="IconBtn"
                      Width="36"
                      Height="36"
                      ToolTip.Tip="Notifications"
                      Command="{Binding GoToNotificationsCommand}">
                <Border Width="36" Height="36" CornerRadius="12" Background="#18FFFFFF">
                  <ic:MaterialIcon Kind="BellOutline"
                                       Width="20"
                                       Height="20"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                </Border>
              </Button>
            </Grid>

            <StackPanel Spacing="7">
              <TextBlock Text="Solde total"
                         FontSize="12"
                         Foreground="#B9D5C6"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsBalanceVisible}">
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static vm:MoneyTextConverter.Instance}">
                      <Binding Path="DisplayTotalBalance"/>
                      <Binding Path="DisplayCurrency"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="{Binding DisplayCurrency, Converter={x:Static vm:MaskedMoneyTextConverter.Instance}}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           IsVisible="{Binding !IsBalanceVisible}"/>
                <Button Classes="IconBtn"
                        Width="34"
                        Height="34"
                        Command="{Binding ToggleBalanceCommand}"
                        VerticalAlignment="Center">
                  <ic:MaterialIcon Kind="{Binding IsBalanceVisible, Converter={x:Static vm:BoolToEyeIconConverter.Instance}}"
                                       Width="18"
                                       Height="18"
                                       Foreground="#DDEEE4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                </Button>
              </StackPanel>
              <TextBlock Text="+ 1 243,50 € ce mois-ci"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#8FD8AF"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border Classes="EcoPanel"
              Margin="14,-48,14,0">
        <StackPanel Spacing="16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Comptes"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#101820"/>
            <Button Grid.Column="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,0"
                    Command="{Binding GoToAccountsCommand}">
              <TextBlock Text="Voir tout"
                         FontSize="12"
                         FontWeight="Bold"
                         Foreground="#168246"
                         VerticalAlignment="Center"/>
            </Button>
          </Grid>

          <ItemsControl ItemsSource="{Binding Accounts}"
                        IsVisible="{Binding HasAccounts}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="domain:Account">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,14">
                  <Border Grid.Column="0" Classes="EcoIconTile">
                    <ic:MaterialIcon Kind="BankOutline"
                                         Width="20"
                                         Height="20"
                                         Foreground="#168246"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#101820"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Iban}"
                               FontSize="11"
                               Foreground="#8A9AA5"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="#101820"
                             VerticalAlignment="Center">
                    <TextBlock.Text>
                      <MultiBinding Converter="{x:Static vm:MoneyTextConverter.Instance}">
                        <Binding Path="Balance"/>
                        <Binding Path="Currency"/>
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" IsVisible="{Binding HasNoAccounts}">
            <Border Grid.Column="0" Classes="EcoIconTile">
              <ic:MaterialIcon Kind="BankOutline" Width="20" Height="20" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
              <TextBlock Text="{Binding EmptyAccountsMessage}" FontSize="13" FontWeight="Bold" Foreground="#101820"/>
              <TextBlock Text="Actualisez le tableau de bord ou vérifiez votre accès bancaire." FontSize="11" Foreground="#8A9AA5" TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="EcoPanel" Margin="16,0">
        <StackPanel Spacing="10">
          <TextBlock Text="Alertes"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#101820"/>
          <ItemsControl ItemsSource="{Binding DashboardAlerts}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,0,0,8">
                  <Border Classes="EcoIconTile" Width="34" Height="34">
                    <ic:MaterialIcon Kind="BellOutline" Width="18" Height="18" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" Foreground="#45545F" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="EcoPanel" Margin="16,0">
        <StackPanel Spacing="14">
          <TextBlock Text="Actions rapides"
                     FontSize="15"
                     FontWeight="Bold"
                     Foreground="#101820"/>
          <UniformGrid Rows="1" Columns="4">
            <Button Classes="QuickAction" Command="{Binding GoToTransferCommand}">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <Border Classes="EcoIconTile">
                  <ic:MaterialIcon Kind="BankTransfer" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Virement" FontSize="10" FontWeight="SemiBold" Foreground="#45545F" HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="QuickAction" Command="{Binding GoToPaymentCommand}">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <Border Classes="EcoIconTile">
                  <ic:MaterialIcon Kind="CreditCardOutline" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Paiement" FontSize="10" FontWeight="SemiBold" Foreground="#45545F" HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="QuickAction" Command="{Binding GoToAccountsCommand}">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <Border Classes="EcoIconTile">
                  <ic:MaterialIcon Kind="RepeatVariant" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Recharger" FontSize="10" FontWeight="SemiBold" Foreground="#45545F" HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="QuickAction" Command="{Binding GoToNotificationsCommand}">
              <StackPanel Spacing="7" HorizontalAlignment="Center">
                <Border Classes="EcoIconTile">
                  <ic:MaterialIcon Kind="DotsHorizontal" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Plus" FontSize="10" FontWeight="SemiBold" Foreground="#45545F" HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
          </UniformGrid>
        </StackPanel>
      </Border>

      <Border Classes="EcoPanel" Margin="16,0">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
          <StackPanel Grid.Column="0" Spacing="8">
            <TextBlock Text="Impact environnemental"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#101820"/>
            <TextBlock Text="Ce mois-ci"
                       FontSize="12"
                       Foreground="#8A9AA5"/>
            <TextBlock Text="CO₂ évité"
                       FontSize="12"
                       Foreground="#45545F"/>
            <TextBlock Text="128,4 kg"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#101820"/>
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10" Margin="0,8,0,0">
              <Border Grid.Column="0" Height="2" Background="#B8D8BE" VerticalAlignment="Bottom"/>
              <Border Grid.Column="1" Height="3" Background="#9BCFA8" VerticalAlignment="Bottom"/>
              <Border Grid.Column="2" Height="4" Background="#7FC290" VerticalAlignment="Bottom"/>
              <Border Grid.Column="3" Height="12" Background="#34A968" VerticalAlignment="Bottom"/>
              <Border Grid.Column="4" Height="30" Background="#168246" VerticalAlignment="Bottom"/>
            </Grid>
          </StackPanel>

          <Border Grid.Column="1"
                  Width="82"
                  Height="102"
                  Background="#E7F7EE"
                  CornerRadius="40,40,18,18"
                  VerticalAlignment="Bottom">
            <Grid>
              <ic:MaterialIcon Kind="Leaf"
                                   Width="58"
                                   Height="58"
                                   Foreground="#168246"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
