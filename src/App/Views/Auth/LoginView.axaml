<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Auth"
             xmlns:auth="using:EcoBank.App.Views.Auth"
             xmlns:ic="using:IconPacks.Avalonia.Material"
             x:Class="EcoBank.App.Views.Auth.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#F7FCF8">

  <UserControl.Styles>
    <Style Selector="Button.Ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="BorderBrush" Value="#168246" />
      <Setter Property="Foreground" Value="#168246" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Padding" Value="24,14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="16" />
    </Style>
    <Style Selector="Button.Ghost:pointerover">
      <Setter Property="Background" Value="#E7F7EE" />
    </Style>
    <Style Selector="Button.PrimaryAction">
      <Setter Property="Background" Value="#168246" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="0,16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.PrimaryAction:pointerover">
      <Setter Property="Background" Value="#0F6738" />
    </Style>
    <Style Selector="Button.ProfileMenuButton">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#EEF2F4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Width" Value="54" />
      <Setter Property="Height" Value="54" />
      <Setter Property="Padding" Value="15" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.ProfileMenuButton /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.ProfileCardButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ProfileCardButton /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.AddProfilePanel">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.AddProfilePanel /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer x:Name="AuthScrollViewer">
    <Panel Margin="0">
      
      <!-- ============================================== -->
      <!-- STATE: PROFILE SELECTION                       -->
      <!-- ============================================== -->
      <StackPanel IsVisible="{Binding IsProfileSelectionState}" HorizontalAlignment="Center" MaxWidth="500" Margin="30,28,30,24" Spacing="0">

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,28">
          <ic:PackIconMaterial Kind="Leaf" Width="36" Height="36" Foreground="#168246" VerticalAlignment="Center" />
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="0">
            <TextBlock Text="Eco" FontSize="34" FontWeight="Medium" Foreground="#168246" />
            <TextBlock Text="Bank" FontSize="34" FontWeight="Medium" Foreground="#101820" />
          </StackPanel>
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,26">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="Bonjour" FontSize="38" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center" />
            <ic:PackIconMaterial Kind="HandWave" Width="30" Height="30" Foreground="#E8A23A" VerticalAlignment="Center" />
          </StackPanel>
          <Border Grid.Column="1" CornerRadius="27" BoxShadow="0 6 18 0 #18101820">
            <Button Classes="ProfileMenuButton">
              <StackPanel Width="6" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse Width="5" Height="5" Fill="#101820" />
                <Ellipse Width="5" Height="5" Fill="#101820" />
                <Ellipse Width="5" Height="5" Fill="#101820" />
              </StackPanel>
            </Button>
          </Border>
        </Grid>

        <TextBlock Text="SÉLECTIONNEZ UN PROFIL" FontSize="15" FontWeight="Bold" Foreground="#60717D" LetterSpacing="1.2" Margin="0,0,0,16" />

        <ItemsControl ItemsSource="{Binding Profiles}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Classes="ProfileCardButton"
                      Command="{Binding $parent[UserControl].((vm:LoginViewModel)DataContext).SelectProfileCommand}"
                      CommandParameter="{Binding}"
                      Width="360"
                      Margin="0,0,0,24">
                <Border Background="#FFFFFF"
                        CornerRadius="28"
                        ClipToBounds="True"
                        BorderBrush="#EEF2F4"
                        BorderThickness="1"
                        BoxShadow="0 14 34 0 #1A101820">
                  <Grid RowDefinitions="130,Auto">
                    <Border Grid.Row="0" CornerRadius="28,28,0,0" ClipToBounds="True">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                          <GradientStop Color="#07351F" Offset="0" />
                          <GradientStop Color="#168246" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                      <Grid>
                        <Ellipse Width="210"
                                 Height="210"
                                 Fill="#14239A5B"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,0,-46,0" />
                        <ic:PackIconMaterial Kind="Leaf"
                                             Width="168"
                                             Height="168"
                                             Foreground="#24239A5B"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Margin="0,0,28,0"
                                             RenderTransformOrigin="0.5,0.5">
                          <ic:PackIconMaterial.RenderTransform>
                            <RotateTransform Angle="-22" />
                          </ic:PackIconMaterial.RenderTransform>
                        </ic:PackIconMaterial>
                        <Border Width="76"
                                Height="76"
                                CornerRadius="38"
                                Background="#FFFFFF"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="32,0,0,0"
                                BoxShadow="0 10 26 0 #30101820">
                          <ic:PackIconMaterial Kind="Sprout" Width="44" Height="44" Foreground="#0F6738" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                      </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="30,18,26,18">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="8">
                          <TextBlock Text="{Binding DisplayName}" FontSize="23" FontWeight="Bold" Foreground="#101820" />
                          <TextBlock Text="{Binding MaskedClientId}" FontSize="17" Foreground="#60717D" />
                          <TextBlock Text="EcoBank" FontSize="17" Foreground="#8A9AA5" Margin="0,0,0,12" />

                          <Border Background="#E7F7EE" CornerRadius="20" Padding="10,7" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <ic:PackIconMaterial Kind="CheckCircle" Width="20" Height="20" Foreground="#168246" VerticalAlignment="Center" />
                              <TextBlock Text="Profil actif" FontSize="15" FontWeight="Bold" Foreground="#168246" VerticalAlignment="Center" />
                            </StackPanel>
                          </Border>
                        </StackPanel>

                        <ic:PackIconMaterial Grid.Column="1" Kind="ChevronRight" Width="34" Height="34" Foreground="#60717D" VerticalAlignment="Bottom" Margin="0,0,0,10" />
                      </Grid>
                    </Border>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Classes="AddProfilePanel"
                Command="{Binding NavigateToAddProfileCommand}"
                Width="360"
                Margin="0">
          <Panel Height="112">
            <Rectangle RadiusX="18"
                       RadiusY="18"
                       Fill="Transparent"
                       Stroke="#168246"
                       StrokeThickness="1.4"
                       StrokeDashArray="7,7" />
            <StackPanel Orientation="Horizontal" Spacing="18" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0">
              <ic:PackIconMaterial Kind="PlusCircleOutline" Width="36" Height="36" Foreground="#168246" />
              <TextBlock Text="Ajouter un profil" FontSize="20" FontWeight="Medium" Foreground="#168246" VerticalAlignment="Center" />
            </StackPanel>
          </Panel>
        </Button>

        <Border Background="#EAF6EF"
                CornerRadius="16"
                Padding="18"
                Margin="0,68,0,0"
                BorderBrush="#DDF5E7"
                BorderThickness="1">
          <Grid ColumnDefinitions="64,*" ColumnSpacing="16">
            <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#FFFFFF" VerticalAlignment="Top">
              <ic:PackIconMaterial Kind="Leaf" Width="34" Height="34" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" Spacing="8">
              <TextBlock Text="Gérez vos finances en toute simplicité" FontSize="18" FontWeight="Medium" Foreground="#101820" TextWrapping="Wrap" />
              <TextBlock Text="Changez de profil à tout moment pour accéder à vos comptes." FontSize="16" Foreground="#60717D" LineHeight="24" TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>


      <!-- ============================================== -->
      <!-- STATE: PIN ENTRY                               -->
      <!-- ============================================== -->
      <StackPanel IsVisible="{Binding IsPinEntryState}" HorizontalAlignment="Center" MaxWidth="500" Margin="24,48,24,24" Spacing="0">
        
        <!-- Profile Pill -->
        <Button Command="{Binding CancelPinEntryCommand}"
                Background="White" 
                BorderThickness="1"
                BorderBrush="#EEF2F4"
                Foreground="#168246" 
                CornerRadius="24" 
                HorizontalAlignment="Center"
                Margin="0,0,0,48"
                Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding SelectedProfile.DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="✕" FontSize="12" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <TextBlock Text="Mes identifiants" FontSize="32" FontWeight="Bold" Foreground="#101820" Margin="0,0,0,8"/>
        <TextBlock Text="Saisissez votre code PIN" FontSize="16" Foreground="#45545F" Margin="0,0,0,48"/>

        <!-- Error message -->
        <Border Background="#FDECEC" CornerRadius="8" Padding="12,10" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" BorderBrush="#D84C4C" BorderThickness="1" Margin="0,0,0,16">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#D84C4C" TextWrapping="Wrap" FontSize="13" TextAlignment="Center"/>
        </Border>

        <!-- OTP PIN Input Component -->
        <auth:OtpPinInput x:Name="OtpPinInput" 
                         OtpValue="{Binding Pin, Mode=TwoWay}"
                         Margin="0,0,0,32" />

        <TextBlock Text="Code PIN oublié ?" 
                   Foreground="#168246" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,64"/>

        <Button Classes="PrimaryAction"
                Content="Continuer"
                Command="{Binding SubmitPinCommand}"
                HorizontalAlignment="Stretch"
                Height="56"/>
      </StackPanel>


      <!-- ============================================== -->
      <!-- STATE: ADD PROFILE                             -->
      <!-- ============================================== -->
      <StackPanel IsVisible="{Binding IsAddProfileState}" HorizontalAlignment="Center" MaxWidth="500" Margin="24,48,24,24" Spacing="0">
        
        <StackPanel Spacing="8" Margin="0,0,0,32">
          <TextBlock Text="EcoBank" FontSize="40" FontWeight="Bold" Foreground="#168246" />
          <TextBlock Text="Ajouter un profil" FontSize="24" FontWeight="Bold" Foreground="#101820"/>
          <TextBlock Text="Saisissez vos informations pour associer votre compte." FontSize="15" Foreground="#45545F" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Margin="0,0,0,24" CornerRadius="16" Padding="24" Background="White" BorderBrush="#EEF2F4" BorderThickness="1" BoxShadow="0 8 24 0 #14101820">
          <StackPanel Spacing="20">
            <TextBox AutomationProperties.Name="Client ID"
                     Watermark="Client ID"
                     Text="{Binding ClientId}"
                     IsEnabled="{Binding !IsBusy}"/>
            <TextBox AutomationProperties.Name="Client Secret"
                     Watermark="Client Secret"
                     Text="{Binding ClientSecret}"
                     PasswordChar="•"
                     IsEnabled="{Binding !IsBusy}"/>
            <TextBox AutomationProperties.Name="App User ID"
                     Watermark="App User ID"
                     Text="{Binding AppUserId}"
                     IsEnabled="{Binding !IsBusy}"/>
            
            <Border Height="1" Background="#EAECEF" Margin="0,8"/>
            
            <TextBlock Text="Définissez un code PIN pour simplifier vos prochaines connexions :" FontSize="14" Foreground="#6C7A89" TextWrapping="Wrap"/>
            
            <TextBox AutomationProperties.Name="Code PIN (Nouveau)"
                     Watermark="Code PIN (Nouveau)"
                     Text="{Binding NewPin}"
                     PasswordChar="•"
                     MaxLength="8"
                     IsEnabled="{Binding !IsBusy}"/>
            
            <Button Command="{Binding ToggleRememberCredentialsCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Background="#F7FCF8"
                    BorderBrush="#E6E8E8"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14,12"
                    HorizontalContentAlignment="Stretch">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Grid.Column="0"
                           Text="{Binding RememberCredentialsLabel}"
                           Foreground="#101820"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Width="48"
                        Height="28"
                        CornerRadius="14"
                        Background="#168246"
                        VerticalAlignment="Center">
                  <Ellipse Width="22"
                           Height="22"
                           Fill="#FFFFFF"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="3"/>
                </Border>
              </Grid>
            </Button>

            <!-- Error message -->
            <Border Background="#FDECEC" CornerRadius="8" Padding="12,10" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" BorderBrush="#D84C4C" BorderThickness="1">
              <TextBlock Text="{Binding ErrorMessage}" Foreground="#D84C4C" TextWrapping="Wrap" FontSize="13"/>
            </Border>

            <Button Classes="PrimaryAction" Content="Enregistrer &amp; Continuer" Command="{Binding LoginCommand}" IsEnabled="{Binding !IsBusy}" HorizontalAlignment="Stretch" Height="56" Margin="0,16,0,0"/>
            
            <Button Content="Annuler" 
                    Command="{Binding CancelAddProfileCommand}" 
                    Background="Transparent" 
                    Foreground="#8A9AA5"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding HasProfiles}"
                    Height="48" />
          </StackPanel>
        </Border>
      </StackPanel>

    </Panel>
  </ScrollViewer>
</UserControl>
