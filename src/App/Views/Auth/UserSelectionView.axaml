<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Auth"
             xmlns:domain="using:EcoBank.Core.Domain.Users"
             x:Class="EcoBank.App.Views.Auth.UserSelectionView"
             x:DataType="vm:UserSelectionViewModel"
             Background="#F7FCF8">

  <DockPanel Background="#F7FCF8">
    <!-- Header -->
    <Border DockPanel.Dock="Top" Padding="16,12" Background="#FFFFFF" BoxShadow="0 12 28 0 #100B2B1B">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Button Grid.Column="0"
                Classes="Secondary"
                Content="← Changer de credentials"
                Command="{Binding ChangeCredentialsCommand}"
                VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1"
                   Text="Sélection de l'utilisateur"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#101820"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Search bar -->
    <Border DockPanel.Dock="Top" Padding="16,12">
      <TextBox Classes="EcoField"
               Text="{Binding SearchQuery}"
               Watermark="🔍  Rechercher un utilisateur..."
               AutomationProperties.Name="Recherche utilisateur"/>
    </Border>

    <!-- Loading -->
    <ProgressBar DockPanel.Dock="Top"
                 IsIndeterminate="True"
                 Height="3"
                 IsVisible="{Binding IsBusy}"/>

    <!-- Error -->
    <Border DockPanel.Dock="Top"
            Background="#FEE2E2"
            Padding="16,10"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C" TextWrapping="Wrap"/>
    </Border>

    <!-- Empty state -->
    <StackPanel DockPanel.Dock="Top"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Margin="32"
                IsVisible="{Binding IsEmpty}">
      <TextBlock Text="🌿" FontSize="48" HorizontalAlignment="Center"/>
      <TextBlock Text="Aucun utilisateur trouvé"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="#101820"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Vérifiez vos credentials ou essayez une autre recherche."
                 Foreground="#45545F"
                 TextWrapping="Wrap"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>
    </StackPanel>

    <!-- User list -->
    <ListBox ItemsSource="{Binding Users}"
             Background="Transparent"
             SelectionMode="Single">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="domain:User">
          <Button Classes="NavItem"
                  HorizontalAlignment="Stretch"
                  Command="{Binding $parent[ListBox].((vm:UserSelectionViewModel)DataContext).SelectUserCommand}"
                  CommandParameter="{Binding}">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="4">
              <TextBlock Grid.Row="0" Grid.Column="0"
                         FontWeight="Bold"
                         Foreground="#101820"
                         FontSize="15">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} {1}">
                    <Binding Path="FirstName"/>
                    <Binding Path="LastName"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
              <TextBlock Grid.Row="1" Grid.Column="0"
                         Text="{Binding AppUserId}"
                         FontSize="13"
                         Foreground="#8A9AA5"/>
              <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                      Classes="BadgeSuccess"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding KycStatus}"
                           FontSize="11"
                           FontWeight="Medium"/>
              </Border>
            </Grid>
          </Button>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
