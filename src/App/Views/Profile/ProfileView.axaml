<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EcoBank.App.ViewModels.Profile"
             xmlns:docs="using:EcoBank.Core.Domain.Documents"
             xmlns:ic="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="EcoBank.App.Views.Profile.ProfileView"
             x:DataType="vm:ProfileViewModel"
             Background="#FFFFFF">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16,14,16,24" Spacing="18">
      <Grid ColumnDefinitions="*,Auto" Height="56">
        <TextBlock Text="Profil"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#101820"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Classes="IconBtn" Width="44" Height="44" VerticalAlignment="Center">
          <ic:MaterialIcon Kind="CogOutline" Width="22" Height="22" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
      </Grid>

      <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,2,0,12">
        <Border Width="76"
                Height="76"
                CornerRadius="38"
                Background="#DCE3E7"
                ClipToBounds="True">
          <Grid>
            <ic:MaterialIcon Kind="Account"
                                 Width="52"
                                 Height="52"
                                 Foreground="#60717D"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <TextBlock Text="{Binding UserDisplayName}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#101820"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding ProfileEmail}"
                   FontSize="12"
                   Foreground="#8A9AA5"
                   HorizontalAlignment="Center"/>
        <Border Background="#E7F7EE" CornerRadius="999" Padding="11,5" HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <ic:MaterialIcon Kind="Leaf" Width="13" Height="13" Foreground="#168246"/>
            <TextBlock Text="Client EcoBank" FontSize="11" FontWeight="Bold" Foreground="#168246"/>
          </StackPanel>
        </Border>
        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
          <ic:MaterialIcon Kind="Leaf" Width="10" Height="10" Foreground="#168246"/>
          <TextBlock Text="Niveau Éco" FontSize="11" FontWeight="Medium" Foreground="#45545F"/>
        </StackPanel>
      </StackPanel>

      <StackPanel Spacing="0">
        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="AccountOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Informations personnelles" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="ShieldCheckOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Sécurité" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="CreditCardOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Moyens de paiement" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="BellOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Notifications" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="FileDocumentOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Documents" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="CogOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Paramètres" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Border Height="1" Background="#EEF2F4"/>

        <Button Background="Transparent" BorderThickness="0" Padding="0,13" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" MinHeight="30">
            <ic:MaterialIcon Kind="HelpCircleOutline" Width="20" Height="20" Foreground="#45545F" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="Aide &amp; support" FontSize="13" FontWeight="Bold" Foreground="#101820" VerticalAlignment="Center"/>
            <ic:MaterialIcon Grid.Column="2" Kind="ChevronRight" Width="18" Height="18" Foreground="#8A9AA5" VerticalAlignment="Center"/>
          </Grid>
        </Button>
      </StackPanel>

      <Border Classes="EcoPanel">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Documents"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#101820"/>
            <Button Grid.Column="1" Classes="IconBtn" Width="34" Height="34" Command="{Binding LoadCommand}">
              <ic:MaterialIcon Kind="Refresh" Width="18" Height="18" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
          </Grid>
          <ProgressBar IsIndeterminate="True" Height="3" IsVisible="{Binding IsBusy}"/>
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#D84C4C" TextWrapping="Wrap" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          <TextBlock Text="{Binding DocumentMessage}" FontSize="12" Foreground="#45545F" TextWrapping="Wrap"/>
          <ItemsControl ItemsSource="{Binding Documents}" IsVisible="{Binding HasDocuments}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="docs:UserDocument">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,12">
                  <Border Classes="EcoIconTile">
                    <ic:MaterialIcon Kind="FileDocumentOutline" Width="19" Height="19" Foreground="#168246" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#101820" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Kind}" FontSize="11" Foreground="#8A9AA5"/>
                  </StackPanel>
                  <Button Grid.Column="2"
                          Classes="IconBtn"
                          Width="34"
                          Height="34"
                          Command="{Binding $parent[ItemsControl].((vm:ProfileViewModel)DataContext).OpenDocumentCommand}"
                          CommandParameter="{Binding}">
                    <ic:MaterialIcon Kind="EyeOutline" Width="18" Height="18" Foreground="#45545F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{Binding DocumentsEmptyMessage}"
                     FontSize="12"
                     Foreground="#8A9AA5"
                     TextWrapping="Wrap"
                     IsVisible="{Binding !HasDocuments}"/>
        </StackPanel>
      </Border>

      <Button Command="{Binding ResetSessionCommand}"
              Background="#FFFFFF"
              BorderBrush="#EEF2F4"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16,14"
              HorizontalContentAlignment="Center"
              Margin="8,8,8,0">
        <TextBlock Text="Se déconnecter"
                   FontSize="13"
                   FontWeight="Bold"
                   Foreground="#D84C4C"/>
      </Button>
    </StackPanel>
  </ScrollViewer>
</UserControl>
