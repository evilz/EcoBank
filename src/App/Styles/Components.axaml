<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ic="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

  <!--
    Design tokens are declared here so that {StaticResource} lookups inside <Setter> elements
    resolve correctly when this Styles file is loaded as part of Application.Styles — before
    Application.Resources has been fully populated.
  -->
  <Styles.Resources>
    <CornerRadius x:Key="RadiusXs">6</CornerRadius>
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusXl">28</CornerRadius>
    <CornerRadius x:Key="RadiusCard">16</CornerRadius>
    <CornerRadius x:Key="RadiusButton">14</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>
    <Thickness x:Key="CardPadding">16</Thickness>
    <x:Double x:Key="MinTouchTarget">48</x:Double>
  </Styles.Resources>

  <!-- ===== ECOBANK LIGHT DESIGN SYSTEM ===== -->
  <Style Selector="TextBlock">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="Button">
    <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
  </Style>

  <Style Selector="Border.Card">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #1A101820" />
  </Style>

  <Style Selector="Border.FinPanel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #14101820" />
  </Style>

  <Style Selector="Border.EcoPanel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #14101820" />
  </Style>

  <Style Selector="Border.EcoSoftPanel">
    <Setter Property="Background" Value="#F1FBF5" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.EcoIconTile">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Background" Value="#E7F7EE" />
  </Style>

  <Style Selector="TextBlock.EcoTitle">
    <Setter Property="Foreground" Value="#101820" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.EcoMuted">
    <Setter Property="Foreground" Value="#45545F" />
  </Style>

  <Style Selector="Border.DarkPanel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #14101820" />
  </Style>

  <Style Selector="Border.CardInteractive">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="BoxShadow" Value="0 8 24 0 #1A101820" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Border.CardInteractive:pointerover">
    <Setter Property="BoxShadow" Value="0 10 30 0 #22101820" />
  </Style>

  <!-- ===== PRIMARY BUTTON - OFFICIAL ECOBANK COLORS ===== -->
  <Style Selector="Button.Primary">
    <Setter Property="Background" Value="#168246" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="16,14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#0F6738" />
  </Style>
  <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#0B4D2D" />
  </Style>
  <Style Selector="Button.Primary:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="#E0E0E0" />
    <Setter Property="Foreground" Value="#7A7F85" />
  </Style>

  <!-- ===== SECONDARY BUTTON ===== -->
  <Style Selector="Button.Secondary">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="Foreground" Value="#168246" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1.2" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- ===== DANGER BUTTON ===== -->
  <Style Selector="Button.Danger">
    <Setter Property="Background" Value="#D84C4C" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- ===== TEXT FIELD - OFFICIAL ECOBANK COLORS ===== -->
  <Style Selector="TextBox.EcoField">
    <Setter Property="Background" Value="#F7FCF8" />
    <Setter Property="BorderBrush" Value="#E6E8E8" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="FontSize" Value="15" />
  </Style>
  <Style Selector="TextBox.EcoField:focus">
    <Setter Property="BorderBrush" Value="#168246" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- ===== AMOUNT COLORS ===== -->
  <Style Selector="TextBlock.AmountCredit">
    <Setter Property="Foreground" Value="#168246" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.AmountDebit">
    <Setter Property="Foreground" Value="#D84C4C" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.AmountPending">
    <Setter Property="Foreground" Value="#8A9AA5" />
  </Style>

  <!-- ===== BADGE ===== -->
  <Style Selector="Border.BadgeSuccess">
    <Setter Property="Background" Value="#E7F7EE" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.BadgeWarning">
    <Setter Property="Background" Value="#FFFBEB" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.BadgeError">
    <Setter Property="Background" Value="#FCE7E7" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <!-- ===== SECTION TITLE ===== -->
  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <!-- ===== NAVIGATION BAR BUTTON ===== -->
  <Style Selector="Button.NavItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="6,6" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="MinWidth" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button.NavItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#12E7F7EE" />
  </Style>

  <!-- ===== TAB ACTIF (ex: Comptes) ===== -->
  <Style Selector="Button.TabActive">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#168246" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="BorderBrush" Value="#168246" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.TabActive /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.TabActive TextBlock">
    <Setter Property="Foreground" Value="#168246" />
  </Style>

  <!-- ===== TAB INACTIF (placeholder) ===== -->
  <Style Selector="Button.TabInactive">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#8A9AA5" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Cursor" Value="Arrow" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>
  <Style Selector="Button.TabInactive /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.TabInactive TextBlock">
    <Setter Property="Foreground" Value="#8A9AA5" />
  </Style>

  <!-- ===== BOUTON ICÔNE (œil, …) ===== -->
  <Style Selector="Button.IconBtn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.IconBtn /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ===== BOUTON CLOCHE ===== -->
  <Style Selector="Button.BellButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.BellButton /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ===== QUICK ACTION BUTTON ===== -->
  <Style Selector="Button.QuickAction">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.QuickAction /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.QuickAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#F1FBF5" />
  </Style>

  <!-- ===== QUICK ACTION ICON CONTAINER ===== -->
  <Style Selector="Border.QuickActionIcon">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="13" />
    <Setter Property="BorderBrush" Value="#EEF2F4" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 2 8 0 #10101820" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <!-- ===== PACKICON MATERIAL ===== -->
  <Style Selector="ic|MaterialIcon">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
  </Style>

</Styles>
