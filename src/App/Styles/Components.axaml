<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ic="using:IconPacks.Avalonia.Material"
        xmlns:conv="using:EcoBank.App.Converters">

  <!--
    Design tokens are declared here so that {StaticResource} lookups inside <Setter> elements
    resolve correctly when this Styles file is loaded as part of Application.Styles — before
    Application.Resources has been fully populated.
  -->
  <Styles.Resources>
    <CornerRadius x:Key="RadiusXs">4</CornerRadius>
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusXl">24</CornerRadius>
    <CornerRadius x:Key="RadiusCard">24</CornerRadius>
    <CornerRadius x:Key="RadiusButton">28</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>
    <Thickness x:Key="CardPadding">16</Thickness>
    <x:Double x:Key="MinTouchTarget">48</x:Double>
  </Styles.Resources>

  <!-- ===== CARD - OFFICIAL ECOBANK TOKENS ===== -->
  <Style Selector="Border.Card">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="BoxShadow" Value="0 10 28 0 #14000000" />
  </Style>

  <Style Selector="Border.FinPanel">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="0 12 30 0 #12000000" />
  </Style>

  <Style Selector="Border.DarkPanel">
    <Setter Property="Background" Value="#242424" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BorderBrush" Value="#16FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 16 32 0 #33000000" />
  </Style>

  <Style Selector="Border.CardInteractive">
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}" />
    <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    <Setter Property="BoxShadow" Value="0 10 30 0 #26000000" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Border.CardInteractive:pointerover">
    <Setter Property="BoxShadow" Value="0 12 40 0 #30000000" />
  </Style>

  <!-- ===== PRIMARY BUTTON - OFFICIAL ECOBANK COLORS ===== -->
  <Style Selector="Button.Primary">
    <Setter Property="Background" Value="#31D6B2" />
    <Setter Property="Foreground" Value="#0F1413" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="16,14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#27C4A2" />
  </Style>
  <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#5AB132" />
  </Style>
  <Style Selector="Button.Primary:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="#E0E0E0" />
    <Setter Property="Foreground" Value="#7A7F85" />
  </Style>

  <!-- ===== SECONDARY BUTTON ===== -->
  <Style Selector="Button.Secondary">
    <Setter Property="Background" Value="#0631D6B2" />
    <Setter Property="Foreground" Value="#168F78" />
    <Setter Property="BorderBrush" Value="#6631D6B2" />
    <Setter Property="BorderThickness" Value="1.2" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- ===== DANGER BUTTON ===== -->
  <Style Selector="Button.Danger">
    <Setter Property="Background" Value="#FF4D4F" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <!-- ===== TEXT FIELD - OFFICIAL ECOBANK COLORS ===== -->
  <Style Selector="TextBox.EcoField">
    <Setter Property="Background" Value="#F7F8F5" />
    <Setter Property="BorderBrush" Value="#E0E0E0" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="FontSize" Value="15" />
  </Style>
  <Style Selector="TextBox.EcoField:focus">
    <Setter Property="BorderBrush" Value="#7ED957" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- ===== AMOUNT COLORS ===== -->
  <Style Selector="TextBlock.AmountCredit">
    <Setter Property="Foreground" Value="#1E7F4F" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.AmountDebit">
    <Setter Property="Foreground" Value="#FF4D4F" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.AmountPending">
    <Setter Property="Foreground" Value="#7A7F85" />
  </Style>

  <!-- ===== BADGE ===== -->
  <Style Selector="Border.BadgeSuccess">
    <Setter Property="Background" Value="#E8F5DB" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.BadgeWarning">
    <Setter Property="Background" Value="#FFFBEB" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>
  <Style Selector="Border.BadgeError">
    <Setter Property="Background" Value="#FCE7E7" />
    <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <!-- ===== SECTION TITLE ===== -->
  <Style Selector="TextBlock.SectionTitle">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>

  <!-- ===== NAVIGATION BAR BUTTON ===== -->
  <Style Selector="Button.NavItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="6,7" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="MinHeight" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="MinWidth" Value="{StaticResource MinTouchTarget}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button.NavItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#1231D6B2" />
  </Style>

  <!-- ===== TAB ACTIF (ex: Comptes) ===== -->
  <Style Selector="Button.TabActive">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#1A7F4F" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="BorderBrush" Value="#1A7F4F" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.TabActive /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.TabActive TextBlock">
    <Setter Property="Foreground" Value="#1A7F4F" />
  </Style>

  <!-- ===== TAB INACTIF (placeholder) ===== -->
  <Style Selector="Button.TabInactive">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#7A7F85" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Cursor" Value="Arrow" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>
  <Style Selector="Button.TabInactive /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.TabInactive TextBlock">
    <Setter Property="Foreground" Value="#7A7F85" />
  </Style>

  <!-- ===== BOUTON ICÔNE (œil, …) ===== -->
  <Style Selector="Button.IconBtn">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.IconBtn /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ===== BOUTON CLOCHE ===== -->
  <Style Selector="Button.BellButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.BellButton /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ===== QUICK ACTION BUTTON ===== -->
  <Style Selector="Button.QuickAction">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,10" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
  </Style>
  <Style Selector="Button.QuickAction /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.QuickAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#F0F0EC" />
  </Style>

  <!-- ===== QUICK ACTION ICON CONTAINER ===== -->
  <Style Selector="Border.QuickActionIcon">
    <Setter Property="Background" Value="#1131D6B2" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <!-- ===== PACKICON MATERIAL (template local) ===== -->
  <Style Selector="ic|PackIconMaterial">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Template">
      <ControlTemplate>
        <Viewbox Stretch="Uniform">
          <Image Source="{Binding Kind, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static conv:MaterialKindToImageConverter.Instance}, ConverterParameter={TemplateBinding Foreground}}" />
        </Viewbox>
      </ControlTemplate>
    </Setter>
  </Style>

</Styles>
