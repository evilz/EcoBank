<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== SPACING ===== -->
  <x:Double x:Key="SpacingXs">4</x:Double>
  <x:Double x:Key="SpacingSm">8</x:Double>
  <x:Double x:Key="SpacingMd">16</x:Double>
  <x:Double x:Key="SpacingLg">24</x:Double>
  <x:Double x:Key="SpacingXl">32</x:Double>
  <x:Double x:Key="SpacingXxl">48</x:Double>
  <x:Double x:Key="ScreenPadding">20</x:Double>
  <Thickness x:Key="CardPadding">16</Thickness>
  <x:Double x:Key="ListItemHeight">72</x:Double>
  <x:Double x:Key="ListItemHeightCompact">56</x:Double>

  <!-- ===== RADIUS - OFFICIAL ECOBANK TOKENS ===== -->
  <CornerRadius x:Key="RadiusXs">6</CornerRadius>
  <CornerRadius x:Key="RadiusSm">8</CornerRadius>
  <CornerRadius x:Key="RadiusMd">12</CornerRadius>
  <CornerRadius x:Key="RadiusLg">16</CornerRadius>
  <CornerRadius x:Key="RadiusCard">16</CornerRadius>
  <CornerRadius x:Key="RadiusButton">14</CornerRadius>
  <CornerRadius x:Key="RadiusXl">28</CornerRadius>
  <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

  <!-- ===== ACCESSIBILITY ===== -->
  <x:Double x:Key="MinTouchTarget">48</x:Double>

  <!-- ===== LIGHT THEME COLORS - OFFICIAL ECOBANK PALETTE ===== -->
  <Color x:Key="LightBackground">#F7FCF8</Color>
  <Color x:Key="LightSurface">#FFFFFF</Color>
  <Color x:Key="LightSurfaceVariant">#F1FBF5</Color>
  <Color x:Key="LightOutline">#EEF2F4</Color>
  <Color x:Key="LightPrimary">#168246</Color>
  <Color x:Key="LightOnPrimary">#FFFFFF</Color>
  <Color x:Key="LightPrimaryContainer">#E7F7EE</Color>
  <Color x:Key="LightSecondary">#239A5B</Color>
  <Color x:Key="LightOnSecondary">#FFFFFF</Color>
  <Color x:Key="LightTertiary">#55BE85</Color>
  <Color x:Key="LightSuccess">#168246</Color>
  <Color x:Key="LightWarning">#E8A23A</Color>
  <Color x:Key="LightError">#D84C4C</Color>
  <Color x:Key="LightOnSurface">#101820</Color>
  <Color x:Key="LightOnSurfaceVariant">#45545F</Color>
  <Color x:Key="LightCredit">#168246</Color>
  <Color x:Key="LightDebit">#101820</Color>
  <Color x:Key="LightPending">#8A9AA5</Color>

  <!-- ===== DARK THEME COLORS - DISABLED FOR NOW ===== -->
  <!-- Dark theme will be enabled in future updates -->
  <!-- When enabled, update with LIGHT theme colors as fallback -->

</ResourceDictionary>
